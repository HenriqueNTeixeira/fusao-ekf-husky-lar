<?xml version="1.0"?>
<!-- Configuracao 3: ODOMETRIA + IMU + GPS -->
<launch>
  <arg name="raw_odom" default="/wheel/odom"/>
  <arg name="raw_imu"  default="/imu/data"/>
  <arg name="raw_fix"  default="/fix"/>

  <!-- navsat_transform: /fix (lat/lon) -> /gps/odom (nav_msgs/Odometry) -->
  <node pkg="robot_localization" type="navsat_transform_node"
        name="navsat_transform_node" clear_params="true" output="screen">
    <rosparam command="load"
              file="$(find lar_fusao_ekf)/config/navsat_transform.yaml"/>
    <!-- entradas -->
    <remap from="/imu/data"           to="$(arg raw_imu)"/>
    <remap from="/gps/fix"            to="$(arg raw_fix)"/>
    <remap from="/odometry/filtered"  to="/odometry/filtered"/>
    <!-- saida: GPS convertido para odometria local -->
    <remap from="/odometry/gps"       to="/gps/odom"/>
  </node>

  <!-- EKF com odom + imu + gps -->
  <node pkg="robot_localization" type="ekf_localization_node"
        name="ekf_filter_node" clear_params="true" output="screen">
    <rosparam command="load"
              file="$(find lar_fusao_ekf)/config/ekf_odom_imu_gps.yaml"/>
    <remap from="/wheel/odom" to="$(arg raw_odom)"/>
    <remap from="/imu/data"   to="$(arg raw_imu)"/>
    <!-- /gps/odom ja e o nome usado no yaml (saida do navsat) -->
  </node>

  <node pkg="lar_fusao_ekf" type="gt_odom.py" name="gt_odom"
        output="screen"/>

  <node pkg="lar_fusao_ekf" type="fusion_error.py" name="fusion_error"
        output="screen">
    <param name="config_name" value="odom_imu_gps"/>
  </node>
</launch>
